# 复制为 .env 后填入真实 key（.env 已在 .gitignore，永不提交）

# DeepSeek API（用于 polish 提示词；OpenAI 兼容协议）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 可选：Anthropic API（如果未来想切回）
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：私仓远程地址（init 时若本机已 gh auth login 会自动 create）
# PROMPT_HELP_VAULT_REMOTE=git@github.com:<your-username>/prompt-help-vault.git
